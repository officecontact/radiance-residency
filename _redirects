# www → non-www canonical redirect (fixes 404 on www subdomain per GSC audit 2026-04-22)
https://www.radianceresidency.com/* https://radianceresidency.com/:splat 301!

# Force .html → extensionless (301 for SEO canonical consolidation).
# The `!` force flag overrides Netlify's default behaviour of serving the
# physical .html file. Without this, Google indexes both URLs (canonical
# mismatch warnings in our SEO audit flagged 25 pages on 2026-04-21).
/index.html                   /                    301!
/blog/index.html              /blog/               301!
/blog/:slug.html              /blog/:slug          301!
/:slug.html                   /:slug               301!

# Clean URLs — extensionless requests serve the .html content
# (Netlify Pretty URLs handles this automatically, but keep explicit
# rewrites as a safety net in case the setting ever gets disabled)
/rooms      /rooms.html     200
/amenities  /amenities.html 200
/contact    /contact.html   200

