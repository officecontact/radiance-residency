RewriteEngine On

# ── 1. www → non-www canonical (301)
RewriteCond %{HTTP_HOST} ^www\.radianceresidency\.com [NC]
RewriteRule ^(.*)$ https://radianceresidency.com/$1 [R=301,L]

# ── 2. Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ── 3. Remove .html extension (canonical redirect, prevents duplicate content)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# ── 4. Blog .html extension removal
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/(blog/[^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

# ── 5. Trailing slash removal (canonical)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ── 6. Blog index: /blog → /blog/ (single hop)
RewriteRule ^blog$ /blog/ [R=301,L]

# ── 7. Clean URLs: serve .html without extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── 8. Keyword cannibalization fix
Redirect 301 /medicaps-hostel-options /hostel-near-medicaps-university
Redirect 301 /medicaps-hostel-options.html /hostel-near-medicaps-university

# ── 9. Packing list variant URLs → canonical
Redirect 301 /hostel-essentials /hostel-packing-list-for-students
Redirect 301 /checklist-for-hostel-students /hostel-packing-list-for-students
Redirect 301 /hostel-packing-checklist /hostel-packing-list-for-students

# ── 10. Pithampur area guide variants
Redirect 301 /pg-near-pithampur /accommodation-near-pithampur-indore
Redirect 301 /hostel-near-pithampur /accommodation-near-pithampur-indore
Redirect 301 /where-to-stay-in-indore-near-pithampur /accommodation-near-pithampur-indore

# ── 11. Paying guest variants
Redirect 301 /pg-in-indore /paying-guest-in-indore
Redirect 301 /paying-guest-indore /paying-guest-in-indore

# ── 12. Weekend getaways redirect
Redirect 301 /blog/weekend-getaways-from-indore-students /blog/places-to-visit-in-indore-for-students

# ── 13. Short URL aliases
Redirect 301 /rules /rules-regulations
Redirect 301 /rules.html /rules-regulations
Redirect 301 /rooms.html /rooms
Redirect 301 /amenities.html /amenities
Redirect 301 /contact.html /contact

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Cache static assets for performance (helps Core Web Vitals)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType application/json "access plus 1 week"
    ExpiresByType text/xml "access plus 1 week"
</IfModule>

# GZIP compression for faster loading
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml image/svg+xml
</IfModule>

# Custom 404 page
ErrorDocument 404 /404.html

# Missing college landing pages — redirect to closest existing page (2026-04-30)
Redirect 301 /hostel-near-sage-university-indore /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-sage-university-indore.html /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-davv-indore /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-davv-indore.html /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-svvv-indore /hostel-near-iist-indore
Redirect 301 /hostel-near-svvv-indore.html /hostel-near-iist-indore
Redirect 301 /hostel-near-indore-institute-of-pharmacy /hostel-in-pigdamber-rau
Redirect 301 /hostel-near-indore-institute-of-pharmacy.html /hostel-in-pigdamber-rau
Redirect 301 /hostel-near-holkar-science-college-indore /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-holkar-science-college-indore.html /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-oriental-college-indore /boys-hostel-in-rau-indore
Redirect 301 /hostel-near-oriental-college-indore.html /boys-hostel-in-rau-indore
